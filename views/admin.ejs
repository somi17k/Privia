<div class="container py-4 py-lg-5">
  <div class="card border-0 shadow-lg mb-4 admin-hero reveal-on-scroll">
    <div class="card-body p-4 p-lg-5">
      <h1 class="fw-bold mb-1">Admin Dashboard</h1>
      <p class="text-muted mb-0">Review identity submissions, approve users, and verify claims.</p>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100 reveal-on-scroll"><div class="card-body"><p class="text-muted mb-1">Total Users</p><h4 class="mb-0"><%= stats.totalUsers %></h4></div></div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100 reveal-on-scroll"><div class="card-body"><p class="text-muted mb-1">Approved</p><h4 class="mb-0 text-success"><%= stats.approvedUsers %></h4></div></div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100 reveal-on-scroll"><div class="card-body"><p class="text-muted mb-1">Pending Approval</p><h4 class="mb-0 text-warning"><%= stats.pendingUsers %></h4></div></div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100 reveal-on-scroll"><div class="card-body"><p class="text-muted mb-1">Rejected</p><h4 class="mb-0 text-danger"><%= stats.rejectedUsers %></h4></div></div>
    </div>
  </div>

  <div class="card shadow-lg border-0 rounded-4 reveal-on-scroll">
    <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <h4 class="fw-semibold text-primary mb-0">Registered Users</h4>
        <form action="/admin" method="GET" class="d-flex gap-2">
          <select class="form-select" name="status">
            <option value="all" <%= filters.status === 'all' ? 'selected' : '' %>>All</option>
            <option value="approved" <%= filters.status === 'approved' ? 'selected' : '' %>>Approved</option>
            <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="rejected" <%= filters.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
          </select>
          <button type="submit" class="btn btn-outline-primary">Apply</button>
        </form>
      </div>

      <% if (users && users.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="text-white" style="background: linear-gradient(90deg, #0d6efd, #6610f2);">
              <tr>
                <th>Name</th>
                <th>ID Proof</th>
                <th>Claim Status</th>
                <th>User Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach((user)=> { %>
                <% const emailClaim = user.claims?.find(c => c.type === 'email_verified'); %>
                <% const proofExt = user.idProof ? user.idProof.split('.').pop().toLowerCase() : ''; %>
                <% const isImageProof = ['jpg','jpeg','png','webp'].includes(proofExt); %>
                <tr>
                  <td class="fw-semibold">
                    <%= user.name %>
                    <% if (user.verified) { %>
                      <span class="badge bg-success ms-2">Approved</span>
                    <% } %>
                  </td>

                  <td>
                    <% if (user.idProof) { %>
                      <a href="/uploads/<%= user.idProof %>" target="_blank" class="text-decoration-none">
                        <% if (isImageProof) { %>
                          <img src="/uploads/<%= user.idProof %>" width="64" height="64" class="rounded shadow-sm object-fit-cover" alt="ID Proof">
                        <% } else { %>
                          <span class="btn btn-sm btn-outline-secondary">View PDF</span>
                        <% } %>
                      </a>
                    <% } else { %>
                      <span class="text-muted">No proof</span>
                    <% } %>
                  </td>

                  <td>
                    <% if (user.verificationStatus !== 'approved') { %>
                      <span class="text-muted">—</span>
                    <% } else if (emailClaim && emailClaim.verified) { %>
                      <span class="badge bg-success">Approved</span>
                    <% } else { %>
                      <span class="badge bg-warning text-dark">Pending</span>
                    <% } %>
                  </td>

                  <td>
                    <% if (user.verificationStatus === 'approved') { %>
                      <span class="badge bg-success">Approved</span>
                    <% } else if (user.verificationStatus === 'rejected') { %>
                      <span class="badge bg-danger">Rejected</span>
                    <% } else { %>
                      <span class="badge bg-secondary">Pending</span>
                    <% } %>
                    <% if (user.rejectionReason) { %>
                      <div class="small text-danger mt-1"><strong>Reason:</strong> <%= user.rejectionReason %></div>
                    <% } %>
                  </td>

                  <td>
                    <div class="d-flex flex-column gap-2">
                      <% if (user.verificationStatus !== 'approved') { %>
                        <form action="/admin/approve-user/<%= user._id %>" method="POST">
                          <button type="submit" class="btn btn-sm btn-primary w-100">Approve User</button>
                        </form>
                      <% } %>

                      <% if (user.verificationStatus === 'approved' && emailClaim && !emailClaim.verified) { %>
                        <form action="/admin/verify/<%= user._id %>/email_verified" method="POST">
                          <button type="submit" class="btn btn-sm btn-success w-100">Verify Claim</button>
                        </form>
                      <% } %>

                      <% if (user.verificationStatus !== 'approved' || (user.verificationStatus === 'approved' && emailClaim && !emailClaim.verified)) { %>
                        <form action="/admin/reject-user/<%= user._id %>" method="POST">
                          <div class="input-group input-group-sm">
                            <input type="text" name="reason" class="form-control" placeholder="Rejection reason" required maxlength="220">
                            <button type="submit" class="btn btn-outline-danger"><%= user.verificationStatus === 'approved' ? 'Reject Claim' : 'Reject' %></button>
                          </div>
                        </form>
                      <% } %>

                      <% if (user.verificationStatus === 'approved' && (!emailClaim || emailClaim.verified)) { %>
                        <span class="text-muted small">No pending action</span>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <div class="d-flex justify-content-between align-items-center mt-3">
          <small class="text-muted">Page <%= pagination.page %> of <%= pagination.totalPages %></small>
          <div class="d-flex gap-2">
            <% if (pagination.hasPrev) { %>
              <a class="btn btn-sm btn-outline-primary" href="/admin?status=<%= filters.status %>&page=<%= pagination.page - 1 %>">Previous</a>
            <% } %>
            <% if (pagination.hasNext) { %>
              <a class="btn btn-sm btn-outline-primary" href="/admin?status=<%= filters.status %>&page=<%= pagination.page + 1 %>">Next</a>
            <% } %>
          </div>
        </div>
      <% } else { %>
        <div class="alert alert-info mb-0">No users found yet.</div>
      <% } %>
    </div>
  </div>

  <div class="surface-card p-4 mt-4 reveal-on-scroll">
    <h5 class="fw-bold mb-2">Admin Knowledge Center</h5>
    <p class="text-muted mb-3">Keep policies and verification team aligned with platform behavior.</p>
    <div class="d-flex flex-wrap gap-2">
      <a class="btn btn-outline-primary" href="/how-it-works"><i class="bi bi-diagram-3 me-1"></i>Review Flow</a>
      <a class="btn btn-outline-primary" href="/security"><i class="bi bi-shield-lock me-1"></i>Security Model</a>
      <a class="btn btn-outline-primary" href="/about"><i class="bi bi-info-circle me-1"></i>Platform Overview</a>
    </div>
  </div>
</div>

<style>
  .admin-hero {
    background:
      linear-gradient(120deg, rgba(12, 25, 46, 0.52), rgba(28, 45, 74, 0.38)),
      url('https://images.unsplash.com/photo-1563986768609-322da13575f3?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
    color: #fff;
  }

  .admin-hero .text-muted {
    color: rgba(226, 236, 255, 0.9) !important;
  }
</style>
