<div class="container py-4 py-lg-5">
  <div class="dashboard-hero surface-card mb-4 reveal-on-scroll">
    <div class="card-body p-4 p-lg-5">
      <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
          <p class="text-uppercase text-info fw-semibold mb-1 small">Privia Identity Dashboard</p>
          <h1 class="fw-bold mb-1">Welcome, <%= user.name %></h1>
          <p class="text-muted mb-0">Manage privacy-first verification and proof sharing.</p>
        </div>
        <span class="badge rounded-pill px-3 py-2 dashboard-status-pill <%= user.verificationStatus === 'approved' ? 'text-bg-success' : (user.verificationStatus === 'rejected' ? 'text-bg-danger' : 'text-bg-warning text-dark') %>">
          <%= user.verificationStatus === 'approved' ? 'Verified Account' : (user.verificationStatus === 'rejected' ? 'Verification Rejected' : 'Verification Pending') %>
        </span>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="surface-card h-100 reveal-on-scroll">
        <div class="card-body p-4">
          <i class="bi bi-stars text-primary mb-2 d-inline-block"></i>
          <p class="text-muted mb-1">Trust Level</p>
          <h4 class="mb-0 fw-bold"><%= user.verified ? 'High' : 'Low' %></h4>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="surface-card h-100 reveal-on-scroll">
        <div class="card-body p-4">
          <i class="bi bi-patch-check text-primary mb-2 d-inline-block"></i>
          <p class="text-muted mb-1">Email Claim</p>
          <h4 class="mb-0 fw-bold"><%= user.claimVerified ? 'Verified' : 'Pending' %></h4>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="surface-card h-100 reveal-on-scroll">
        <div class="card-body p-4">
          <i class="bi bi-calendar-event text-primary mb-2 d-inline-block"></i>
          <p class="text-muted mb-1">Member Since</p>
          <h4 class="mb-0 fw-bold"><%= user.date ? new Date(user.date).toDateString() : '—' %></h4>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="surface-card h-100 dashboard-feature-card reveal-on-scroll">
        <div class="card-body text-center p-4">
          <i class="bi bi-shield-lock fs-3 text-primary"></i>
          <h5 class="fw-semibold mt-2">Security</h5>
          <p class="text-muted mb-0">Your identity data remains encrypted and protected.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="surface-card h-100 dashboard-feature-card reveal-on-scroll">
        <div class="card-body text-center p-4">
          <i class="bi bi-file-earmark-check fs-3 text-primary"></i>
          <h5 class="fw-semibold mt-2">Claims</h5>
          <p class="text-muted mb-0">Share only verified claims instead of raw personal data.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="surface-card h-100 dashboard-feature-card reveal-on-scroll">
        <div class="card-body text-center p-4">
          <i class="bi bi-qr-code fs-3 text-primary"></i>
          <h5 class="fw-semibold mt-2">QR Verification</h5>
          <p class="text-muted mb-0">Generate temporary code and QR for quick verification.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="surface-card reveal-on-scroll">
    <div class="card-body p-4 p-lg-5">
      <h4 class="fw-bold text-primary mb-4">Account Overview</h4>

      <% if (user.verificationStatus === 'approved') { %>
        <div class="alert alert-success d-flex align-items-center gap-3 rounded-3">
          <i class="bi bi-shield-check fs-3"></i>
          <div>
            <strong>Your identity is verified.</strong><br>
            You can generate secure temporary proofs.
          </div>
        </div>
      <% } else if (user.verificationStatus === 'rejected') { %>
        <div class="alert alert-danger d-flex align-items-center gap-3 rounded-3">
          <i class="bi bi-x-octagon fs-4"></i>
          <div>
            <strong>Verification rejected.</strong><br>
            <span>Reason: <%= user.rejectionReason || 'Identity proof did not pass review.' %></span>
          </div>
        </div>
      <% } else { %>
          <div class="alert alert-warning d-flex align-items-center gap-3 rounded-3">
            <i class="bi bi-hourglass-split fs-4"></i>
            <div>
              <strong>Verification pending.</strong><br>
              Please wait for admin approval before proof generation.
            </div>
          </div>
      <% } %>

            <div class="row g-3 mt-1">
              <div class="col-md-6">
                <div class="p-3 bg-light rounded-3 h-100">
                  <p class="text-muted mb-1">Email Claim</p>
                  <p class="fw-semibold mb-0"><%= user.claimVerified ? 'Verified (encrypted identity)' : 'Pending verification' %></p>
                </div>
              </div>
              <div class="col-md-6">
                <div class="p-3 bg-light rounded-3 h-100">
                  <p class="text-muted mb-1">Registered On</p>
                  <p class="fw-semibold mb-0"><%= user.date ? new Date(user.date).toDateString() : '—' %></p>
                </div>
              </div>
            </div>

            <hr class="my-4">

              <% if (user.verificationStatus === 'approved') { %>
                <div class="text-center">
                <div class="d-flex justify-content-center gap-2 flex-wrap">
                  <button class="btn btn-lg px-4 btn-privia" id="generate-proof-btn">
                    <i class="bi bi-lock-fill me-1"></i>Generate Secure Proof
                  </button>
                  <button class="btn btn-lg btn-outline-secondary" id="regenerate-proof-btn">
                    <i class="bi bi-arrow-repeat me-1"></i>Regenerate
                  </button>
                  <button class="btn btn-lg btn-outline-primary" id="show-qr-btn">
                    <i class="bi bi-camera-fill me-1"></i>Show QR Proof
                  </button>
                </div>
                <p class="small text-muted mt-2 mb-0" id="proof-state"></p>

                <div class="mt-3 d-none" id="proof-inline-panel">
                  <div class="card border-0 shadow-sm proof-panel mx-auto">
                    <div class="card-body p-3 p-md-4">
                      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div class="text-start">
                          <p class="small text-muted mb-1">Active Proof Code</p>
                          <p class="fw-bold mb-0" id="active-proof-code">—</p>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                          <span class="badge text-bg-light text-primary border" id="proof-expiry">Valid for 30 seconds</span>
                          <button type="button" class="btn btn-sm btn-outline-primary" id="copy-proof-btn">Copy Code</button>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="mt-3 d-none" id="qr-wrapper">
                  <div class="card border-0 shadow-sm proof-panel mx-auto">
                    <div class="card-body p-3 p-md-4">
                      <div class="d-flex justify-content-center mt-3">
                        <div class="qr-frame">
                          <canvas id="qr-canvas"></canvas>
                        </div>
                      </div>

                      <p class="small text-muted text-center mt-2 mb-0">
                        Show this QR only during live verification.
                      </p>
                    </div>
                  </div>
                </div>
              </div>
              <% } else if (user.verificationStatus === 'rejected') { %>
                <div class="alert alert-danger text-start mt-3 mb-0">
                  <strong>Re-submit identity proof required.</strong>
                  <p class="mb-2 mt-1">Reason: <%= user.rejectionReason || 'Identity proof did not pass review.' %></p>
                  <form action="/users/resubmit-proof" method="POST" enctype="multipart/form-data" class="d-flex flex-column flex-md-row gap-2">
                    <input type="file" class="form-control" name="idProof" accept=".jpg,.jpeg,.png,.pdf" required>
                    <button type="submit" class="btn btn-danger">Re-submit Proof</button>
                  </form>
                </div>
              <% } else { %>
                <div class="alert alert-warning text-center mt-3 mb-0">
                  Your identity is not verified yet. Please wait for admin approval.
                </div>
              <% } %>
    </div>
  </div>

  <div class="surface-card p-4 mt-4 reveal-on-scroll">
    <h5 class="fw-bold mb-3">Explore More</h5>
    <div class="d-flex flex-wrap gap-2">
      <a href="/how-it-works" class="btn btn-outline-primary"><i class="bi bi-diagram-3 me-1"></i>How It Works</a>
      <a href="/security" class="btn btn-outline-primary"><i class="bi bi-shield-check me-1"></i>Security</a>
      <a href="/about" class="btn btn-outline-primary"><i class="bi bi-info-circle me-1"></i>About Privia</a>
      <a href="/scanner" class="btn btn-outline-primary"><i class="bi bi-qr-code-scan me-1"></i>Open Scanner</a>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/qrcode/build/qrcode.min.js"></script>

<script>
  document.addEventListener("DOMContentLoaded", () => {

    const generateBtn = document.getElementById("generate-proof-btn");
    const qrBtn = document.getElementById("show-qr-btn");
    const regenerateBtn = document.getElementById("regenerate-proof-btn");
    const qrCanvas = document.getElementById("qr-canvas");
    const qrWrapper = document.getElementById("qr-wrapper");
    const proofInlinePanel = document.getElementById("proof-inline-panel");
    const proofExpiry = document.getElementById("proof-expiry");
    const proofCodeValueEl = document.getElementById("active-proof-code");
    const proofStateEl = document.getElementById("proof-state");
    const copyProofBtn = document.getElementById("copy-proof-btn");

    if (!generateBtn || !qrBtn || !regenerateBtn) return; // stops JS for unverified users

    let latestProof = null;
    let countdownTimer = null;

    function startExpiryCountdown(expiresAtISO) {
      if (!proofExpiry) return;
      if (countdownTimer) clearInterval(countdownTimer);

      const expiresAt = new Date(expiresAtISO).getTime();
      const update = () => {
        const remainingMs = expiresAt - Date.now();
        if (remainingMs <= 0) {
          proofExpiry.textContent = "Expired";
          if (proofStateEl) proofStateEl.textContent = "Proof expired. Click Regenerate to issue a new proof.";
          latestProof = null;
          if (countdownTimer) clearInterval(countdownTimer);
          return;
        }

        const totalSeconds = Math.floor(remainingMs / 1000);
        const minutes = Math.floor(totalSeconds / 60);
        const seconds = totalSeconds % 60;
        proofExpiry.textContent = `Expires in ${minutes}:${String(seconds).padStart(2, '0')}`;
      };

      update();
      countdownTimer = setInterval(update, 1000);
    }

    async function fetchProof(forceRegenerate = false) {
      const url = forceRegenerate ? "/proof?regenerate=1" : "/proof";
      const res = await fetch(url);
      const proof = await res.json();

      if (!res.ok || !proof.code) {
        throw new Error(proof.error || "Proof generation failed");
      }

      latestProof = proof;
      if (proofInlinePanel) proofInlinePanel.classList.remove("d-none");
      if (proof.expiresAt) startExpiryCountdown(proof.expiresAt);
      if (proofCodeValueEl) proofCodeValueEl.textContent = proof.code;
      if (proofStateEl) {
        proofStateEl.textContent = forceRegenerate
          ? "New proof issued for this session."
          : "Proof is active for scanning.";
      }
      return proof;
    }

    function renderQr(proof) {
      const ctx = qrCanvas.getContext("2d");
      ctx.clearRect(0, 0, qrCanvas.width, qrCanvas.height);
      const verificationUrl = `${window.location.origin}/verify/proof/${encodeURIComponent(proof.code)}`;

      QRCode.toCanvas(
        qrCanvas,
        verificationUrl,
        { width: 190, margin: 1 },
        (error) => {
          if (error) console.error(error);
        }
      );
    }

    // Generate JSON proof
    generateBtn.addEventListener("click", async () => {
      generateBtn.disabled = true;
      if (proofStateEl) proofStateEl.textContent = "Generating secure proof...";

      try {
        const proof = await fetchProof();
        if (!qrWrapper.classList.contains("d-none")) {
          renderQr(proof);
        }
      } catch (err) {
        if (proofStateEl) proofStateEl.textContent = err.message;
      } finally {
        generateBtn.disabled = false;
      }
    });

    regenerateBtn.addEventListener("click", async () => {
      regenerateBtn.disabled = true;
      try {
        const proof = await fetchProof(true);
        if (!qrWrapper.classList.contains("d-none")) {
          renderQr(proof);
        }
      } catch (err) {
        if (proofStateEl) proofStateEl.textContent = err.message || "Failed to regenerate proof";
      } finally {
        regenerateBtn.disabled = false;
      }
    });

    // 📷 Generate QR proof
    qrBtn.addEventListener("click", async () => {
      try {
        if (!qrWrapper.classList.contains("d-none")) {
          qrWrapper.classList.add("d-none");
          qrBtn.innerHTML = '<i class="bi bi-camera-fill me-1"></i>Show QR Proof';
          if (proofStateEl) proofStateEl.textContent = "QR proof hidden.";
          return;
        }

        const proof = latestProof || await fetchProof();
        renderQr(proof);
        qrWrapper.classList.remove("d-none");
        qrBtn.innerHTML = '<i class="bi bi-eye-slash-fill me-1"></i>Hide QR Proof';
        if (proofStateEl) proofStateEl.textContent = "QR proof ready to scan.";
      } catch (err) {
        if (proofStateEl) proofStateEl.textContent = err.message || "Failed to generate QR proof";
      }
    });

    if (copyProofBtn) {
      copyProofBtn.addEventListener("click", async () => {
        const code = latestProof?.code || proofCodeValueEl?.textContent;
        if (!code || code.includes("Generating")) return;
        try {
          await navigator.clipboard.writeText(code);
          copyProofBtn.textContent = "Copied";
          setTimeout(() => {
            copyProofBtn.textContent = "Copy Code";
          }, 1500);
        } catch {
          copyProofBtn.textContent = "Copy Failed";
          setTimeout(() => {
            copyProofBtn.textContent = "Copy Code";
          }, 1500);
        }
      });
    }

  });

</script>
<style id="b8t7z2">
  .dashboard-hero {
    background:
      linear-gradient(120deg, rgba(12, 25, 46, 0.54), rgba(28, 45, 74, 0.4)),
      url('https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
    color: #fff;
  }

  .dashboard-hero .text-muted,
  .dashboard-hero p {
    color: rgba(229, 237, 255, 0.9) !important;
  }

  .dashboard-status-pill {
    font-size: 0.85rem;
    letter-spacing: 0.2px;
  }

  .dashboard-feature-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .dashboard-feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 0.75rem 1.25rem rgba(13, 110, 253, 0.1) !important;
  }

  .proof-panel {
    max-width: 360px;
  }

  .qr-frame {
    background: #fff;
    border: 1px solid #e9ecef;
    border-radius: 12px;
    padding: 12px;
    box-shadow: inset 0 0 0 1px rgba(13, 110, 253, 0.06);
  }
</style>
