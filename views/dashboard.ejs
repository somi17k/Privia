<div class="container py-5">

  <!-- Dashboard Header -->
  <div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-body">
      <h5 class="fw-semibold text-primary">Your Privia Identity</h5>

      <p class="mb-1">
      <div class="d-flex align-items-center gap-2">
        <strong>Status:</strong>

        <% if (user.verified) { %>
          <span class="badge bg-success px-3 py-2 fs-6 shadow-sm">
            ✔ Verified
          </span>
          <% } else { %>
            <span class="badge bg-warning text-dark px-3 py-2 fs-6 shadow-sm">
              ⏳ Pending Verification
            </span>
            <% } %>
      </div>
      </p>

      <p class="mb-1">
        Trust Level:
        <span class="badge bg-info text-dark">
          <%= user.verified ? 'Medium' : 'Low' %>
        </span>
      </p>

      <p class="text-muted mb-0">
        Last Verified:
        <%= user.verified ? new Date().toDateString() : '—' %>
      </p>
    </div>
  </div>

  <div class="text-center mb-5">
    <h1 class="fw-bold" style="background: linear-gradient(90deg, #0d6efd, #6610f2);
             background-clip: text;
             -webkit-background-clip: text;
             color: transparent;">
      Welcome, <%= user.name %> 👋
        <div class="row text-center mb-4">

          <div class="col-md-4">
            <div class="card shadow-sm p-3">
              <h5>🔐 Security</h5>
              <p class="small text-muted">Your data is encrypted and protected</p>
            </div>
          </div>

          <div class="col-md-4">
            <div class="card shadow-sm p-3">
              <h5>📄 Claims</h5>
              <p class="small text-muted">Generate verifiable identity proofs</p>
            </div>
          </div>

          <div class="col-md-4">
            <div class="card shadow-sm p-3">
              <h5>📷 QR Verification</h5>
              <p class="small text-muted">Scan and verify instantly</p>
            </div>
          </div>

        </div>
    </h1>
    <p class="text-muted">Your privacy-preserving digital identity dashboard</p>
  </div>

  <!-- User Info Card -->
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4">
          <h4 class="fw-semibold text-primary mb-3">Account Overview</h4>
          <% if (user.verified) { %>
            <div class="alert alert-success d-flex align-items-center gap-3 shadow-sm rounded-3">
              <div style="font-size: 1.8rem;">🛡️</div>
              <div>
                <strong>Your identity is verified</strong><br>
                You can now generate secure verification proofs.
              </div>
            </div>
            <% } else { %>
              <div class="alert alert-warning d-flex align-items-center gap-3 shadow-sm rounded-3">
                <div style="font-size: 1.8rem;">⚠️</div>
                <div>
                  <strong>Verification Pending</strong><br>
                  Please wait for admin approval after ID verification.
                </div>
              </div>
              <% } %>
                <p><strong>Email:</strong>
                  <%= user.email %>
                </p>

                <% if (user.date) { %>
                  <p><strong>Registered on:</strong>
                    <%= new Date(user.date).toDateString() %>
                  </p>
                  <% } %>

                    <hr class="my-4">

                    <!-- 🔒 ONLY VERIFIED USERS CAN GENERATE PROOF -->
                    <% if (user.verified) { %>

                      <div class="text-center">

                        <button class="btn btn-lg px-4 shadow" id="generate-proof-btn"
                          style="background: linear-gradient(90deg, #0d6efd, #6610f2); color:white; border:none;">
                          🔒 Generate Secure Proof
                        </button>

                        <button class="btn btn-outline-primary mt-2" id="show-qr-btn">
                          📷 Show QR Proof
                        </button>

                        <div class="mt-3">
                          <div class="mt-4 d-flex justify-content-center">
                            <div class="p-3 bg-light rounded shadow-sm">
                              <canvas id="qr-canvas"></canvas>
                            </div>
                          </div>
                        </div>

                      </div>

                      <% } else { %>

                        <!-- 🚫 UNVERIFIED USER MESSAGE -->
                        <div class="alert alert-warning text-center mt-3">
                          Your identity is not verified yet.<br>
                          Please wait for admin approval before generating verification proof.
                        </div>

                        <% } %>

        </div>
      </div>
    </div>
  </div>

  <!-- Proof Modal -->
  <div class="modal fade" id="proofModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content rounded-4">
        <div class="modal-header border-0">
          <h5 class="modal-title fw-bold text-primary">
            ✅ Proof Generated Successfully
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body text-center">
          <p class="text-muted mb-4">
            Your cryptographic identity proof has been created securely.
          </p>
          <div id="proof-code" style="
          font-size: 28px;
          font-weight: bold;
          letter-spacing: 3px;
          color: #0d6efd;
          background: #f8f9fa;
          padding: 15px;
          border-radius: 10px;
          text-align: center;">
          </div>
        </div>

        <div class="modal-footer border-0">
          <button type="button" class="btn btn-primary" data-bs-dismiss="modal">
            Close
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/qrcode/build/qrcode.min.js"></script>

<script>
  document.addEventListener("DOMContentLoaded", () => {

    const generateBtn = document.getElementById("generate-proof-btn");
    const qrBtn = document.getElementById("show-qr-btn");
    const qrCanvas = document.getElementById("qr-canvas");

    const proofModalEl = document.getElementById("proofModal");
    const proofCode = document.getElementById("proof-code");

    if (!generateBtn || !qrBtn) return; // stops JS for unverified users

    const proofModal = new bootstrap.Modal(proofModalEl);

    // 🔒 Generate JSON proof
    generateBtn.addEventListener("click", async () => {
      proofCode.textContent = "Generating secure proof...";

      try {
        const res = await fetch("/proof");
        const proof = await res.json();

        proofCode.textContent = proof.code;
        proofModal.show();
      } catch (err) {
        proofCode.textContent = "Error generating proof";
      }
    });

    // 📷 Generate QR proof
    qrBtn.addEventListener("click", async () => {
      try {
        const res = await fetch("/proof");
        const proof = await res.json();

        const ctx = qrCanvas.getContext("2d");
        ctx.clearRect(0, 0, qrCanvas.width, qrCanvas.height);

        QQRCode.toCanvas(
          qrCanvas,
          proof.code,
          { width: 250 },
          (error) => {
            if (error) console.error(error);
          }
        );
      } catch (err) {
        alert("Failed to generate QR proof");
      }
    });

  });

</script>
<style id="b8t7z2">
  button:hover {
    transform: scale(1.03);
    transition: 0.2s ease;
  }
</style>