<!DOCTYPE html>
<html>

<head>
  <title>Login - Privia</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body
  style="background: linear-gradient(135deg, #0d6efd, #6610f2); min-height:100vh; display:flex; align-items:center; justify-content:center;">

  <div class="card shadow-lg p-4" style="width: 350px; border-radius:15px;">

    <div class="text-center mb-3">
      <h2 class="fw-bold text-primary">Privia</h2>
      <p class="text-muted small">Secure Identity Registration</p>
    </div>

    <div class="card mx-auto mt-5 p-4" style="max-width: 400px;">
      <h2 class="text-center mb-3">Create Account</h2>

      <form action="/users/register" method="POST" enctype="multipart/form-data">

        <input class="form-control mb-2" type="text" name="name" placeholder="Full Name" required>

        <input class="form-control mb-2" type="email" name="email" placeholder="Email" required>

        <input class="form-control mb-2" type="password" name="password" placeholder="Password" required>

        <!-- ✅ Confirm Password -->
        <input class="form-control mb-2" type="password" name="password2" placeholder="Confirm Password" required>

        <!-- ✅ MUST match backend (idProof) -->
        <input class="form-control mb-3" type="file" name="idProof" accept=".jpg,.jpeg,.png,.pdf" required>

        <button class="btn btn-primary w-100">Register</button>
      </form>

      <a href="/users/login" class="d-block text-center mt-2">
        Already have an account? Login
      </a>
    </div>

</body>

</html>