  <section class="row g-3 mb-4 mb-lg-5">
    <div class="col-6 col-lg-3">
      <div class="surface-card p-3 h-100 text-center reveal-on-scroll">
        <h5 class="fw-bold text-primary mb-1"><span class="count-up" data-count="256">0</span>-bit</h5>
        <p class="small text-muted mb-0">AES data protection</p>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="surface-card p-3 h-100 text-center reveal-on-scroll">
        <h5 class="fw-bold text-primary mb-1"><span class="count-up" data-count="100">0</span>%</h5>
        <p class="small text-muted mb-0">Claim-first verification design</p>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="surface-card p-3 h-100 text-center reveal-on-scroll">
        <h5 class="fw-bold text-primary mb-1"><span class="count-up" data-count="30">0</span>s</h5>
        <p class="small text-muted mb-0">Proof validity window</p>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="surface-card p-3 h-100 text-center reveal-on-scroll">
        <h5 class="fw-bold text-primary mb-1"><span class="count-up" data-count="1">0</span>-time</h5>
