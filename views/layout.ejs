<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Privia | <%- typeof title !== 'undefined' ? title : 'Privacy-Preserving ID' %></title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

  <style>
    :root {
      --privia-primary: #0d6efd;
      --privia-secondary: #6610f2;
      --privia-text: #e7eeff;
      --privia-muted: #a8b6d6;
      --privia-surface: rgba(10, 20, 40, 0.78);
      --privia-bg: #040915;
      --privia-gradient: linear-gradient(90deg, #0d6efd, #6610f2);
      --privia-shadow: 0 12px 30px rgba(3, 8, 20, 0.45);
    }

    body {
      margin: 0;
      font-family: 'Inter', sans-serif;
      color: var(--privia-text);
      background:
        radial-gradient(circle at 15% -12%, rgba(30, 107, 255, 0.2), transparent 30%),
        radial-gradient(circle at 88% -8%, rgba(102, 16, 242, 0.16), transparent 28%),
        radial-gradient(circle at 50% 100%, rgba(22, 44, 92, 0.28), transparent 46%),
        var(--privia-bg);
    }

    body.home-page {
      background: #040915;
    }

    h1, h2, h3, h4, h5, .navbar-brand, .nav-link, .brand-label {
      font-family: 'Montserrat', sans-serif;
    }

    .premium-shell {
      position: relative;
      overflow: hidden;
      isolation: isolate;
      margin-bottom: 1.25rem;
    }

    .premium-shell.home-hero {
      margin-bottom: 0;
      min-height: 112vh;
    }

    .premium-shell::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(180deg, rgba(8, 16, 31, 0.46), rgba(8, 16, 31, 0.3)),
        var(--hero-image) center/cover no-repeat;
      height: 270px;
      z-index: 0;
    }

    .premium-shell.home-hero::before {
      display: none;
    }

    .hero-video-bg {
      position: absolute;
      inset: 0;
      height: 112vh;
      min-height: 760px;
      z-index: 0;
      overflow: hidden;
    }

    .hero-video-bg video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transform: scale(1.02);
    }

    .hero-video-bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(4, 9, 20, 0.44), rgba(4, 9, 20, 0.34) 45%, rgba(4, 9, 20, 0.74)),
        radial-gradient(circle at 82% 18%, rgba(95, 140, 255, 0.24), transparent 40%);
    }

    .navbar {
      position: relative;
      z-index: 3;
      background: transparent;
      border-bottom: 1px solid rgba(255, 255, 255, 0.34);
    }

    .navbar-brand,
    .nav-link,
    .header-icon-link {
      color: #f8fbff !important;
      text-shadow: 0 2px 8px rgba(5, 8, 20, 0.28);
    }

    .navbar-brand {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.35px;
    }

    .brand-mark {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: radial-gradient(circle at 35% 35%, #9fd3ff, #1976ff 45%, #0d2f74 100%);
      box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.2);
    }

    .nav-link {
      border-radius: 999px;
      padding: 0.42rem 0.82rem !important;
      transition: all 0.2s ease;
      font-weight: 600;
      font-size: 0.95rem;
      opacity: 0.97;
    }

    .nav-link:hover,
    .nav-link.active {
      background: rgba(255, 255, 255, 0.19);
      opacity: 1;
    }

    .navbar-toggler {
      border-color: rgba(255, 255, 255, 0.55);
    }

    .navbar-toggler-icon {
      filter: invert(1);
    }

    .header-icon-link {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      border: 1px solid rgba(255, 255, 255, 0.38);
      transition: all 0.2s ease;
    }

    .header-icon-link:hover {
      background: rgba(255, 255, 255, 0.2);
      transform: translateY(-1px);
    }

    .page-hero {
      position: relative;
      z-index: 2;
      padding: 1.9rem 0 2.2rem;
    }

    .page-hero-card {
      max-width: 840px;
    }

    .page-hero-card.standard {
      max-width: 760px;
      padding: 0;
    }

    .premium-shell.home-hero .page-hero {
      min-height: calc(112vh - 72px);
      display: flex;
      align-items: flex-start;
      padding: 1rem 0 3rem;
    }

    .home-hero-content {
      width: 100%;
      max-width: none;
      min-height: clamp(520px, 72vh, 760px);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .home-hero-upper {
      max-width: 760px;
      margin-top: 0;
    }

    .page-kicker {
      text-transform: uppercase;
      font-size: 0.72rem;
      letter-spacing: 0.09em;
      font-weight: 700;
      color: rgba(228, 237, 255, 0.88);
      margin-bottom: 0.4rem;
      display: inline-block;
    }

    .page-hero-title {
      font-size: clamp(1.35rem, 2.45vw, 1.95rem);
      margin-bottom: 0.32rem;
      font-weight: 800;
      color: #ffffff;
      text-shadow: 0 5px 22px rgba(8, 12, 22, 0.45);
    }

    .page-hero-subtitle {
      max-width: 760px;
      margin: 0;
      color: rgba(236, 244, 255, 0.9);
      text-shadow: 0 4px 14px rgba(8, 12, 22, 0.38);
    }

    .home-hero-title {
      font-size: clamp(1.7rem, 3vw, 2.7rem);
      line-height: 1.08;
      margin-bottom: 0.5rem;
    }

    .home-hero-subtitle {
      max-width: 500px;
      font-size: clamp(0.94rem, 1.05vw, 1rem);
      margin-bottom: 1rem;
    }

    .home-hero-lower {
      margin-top: auto;
      align-items: stretch !important;
    }

    .home-hero-panel {
      height: auto;
      border: 0;
      background: transparent;
      backdrop-filter: none;
      border-radius: 0;
      box-shadow: none;
    }

    .home-hero-actions-panel {
      padding: 0;
      border: 0;
      background: transparent;
      backdrop-filter: none;
      box-shadow: none;
      height: auto;
    }

    .home-hero-actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.7rem;
      margin-bottom: 0.8rem;
    }

    .home-hero-actions .btn {
      min-width: 172px;
    }

    .home-hero-link {
      color: #d5e4ff;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.96rem;
      border-bottom: 1px solid rgba(213, 228, 255, 0.42);
      padding-bottom: 0.1rem;
    }

    .home-hero-link:hover {
      color: #ffffff;
      border-bottom-color: rgba(255, 255, 255, 0.72);
    }

    .home-hero-panel {
      max-width: 360px;
      margin-left: auto;
      padding: 0;
    }

    .home-hero-panel-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.8rem;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 0.75rem;
      padding: 0.55rem 0.65rem;
      margin-bottom: 0.55rem;
      color: #eef4ff;
      font-size: 0.9rem;
    }

    .home-hero-panel-row span {
      flex: 1;
    }

    .home-hero-panel-row strong {
      white-space: nowrap;
      text-align: right;
    }

    .home-hero-panel-note {
      margin: 0.1rem 0 0;
      color: rgba(236, 244, 255, 0.85);
      font-size: 0.84rem;
    }

    .home-hero-panel-row:last-child {
      margin-bottom: 0;
    }

    .home-hero-points {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
    }

    .hero-point {
      border: 1px solid rgba(255, 255, 255, 0.38);
      background: rgba(18, 31, 55, 0.56);
      color: rgba(239, 245, 255, 0.95);
      border-radius: 999px;
      padding: 0.34rem 0.74rem;
      font-size: 0.8rem;
      font-weight: 600;
      backdrop-filter: blur(2px);
    }

    @media (min-width: 992px) {
      .navbar .container {
        flex-wrap: nowrap;
      }

      .navbar-nav {
        align-items: center;
      }
    }

    .content-wrapper {
      position: relative;
      z-index: 1;
      min-height: calc(100vh - 220px);
      padding-bottom: 2.25rem;
    }

    .btn-privia {
      background: var(--privia-gradient);
      border: none;
      color: white;
      font-weight: 600;
      box-shadow: 0 8px 16px rgba(13, 110, 253, 0.22);
    }

    .btn-privia:hover,
    .btn-privia:focus {
      background: var(--privia-gradient);
      color: white;
      transform: translateY(-1px);
      box-shadow: 0 10px 18px rgba(13, 110, 253, 0.28);
    }

    .surface-card {
      background: var(--privia-surface);
      border: 1px solid rgba(144, 179, 255, 0.18);
      box-shadow: var(--privia-shadow);
      border-radius: 1rem;
      backdrop-filter: blur(3px);
    }

    .card {
      background: rgba(10, 20, 40, 0.82);
      border: 1px solid rgba(144, 179, 255, 0.18);
      color: var(--privia-text);
    }

    .text-muted,
    .form-text,
    .text-light-emphasis {
      color: var(--privia-muted) !important;
    }

    .form-control,
    .form-select {
      background: rgba(6, 14, 30, 0.78);
      border: 1px solid rgba(144, 179, 255, 0.2);
      color: #ebf2ff;
    }

    .form-control::placeholder {
      color: rgba(194, 206, 230, 0.7);
    }

    .form-control:focus,
    .form-select:focus {
      background: rgba(8, 18, 36, 0.9);
      color: #ebf2ff;
      border-color: rgba(88, 141, 255, 0.65);
      box-shadow: 0 0 0 0.2rem rgba(64, 126, 255, 0.2);
    }

    .table {
      --bs-table-bg: transparent;
      --bs-table-color: #e9efff;
      --bs-table-border-color: rgba(138, 168, 230, 0.2);
      --bs-table-hover-bg: rgba(68, 116, 228, 0.15);
      --bs-table-hover-color: #ffffff;
      margin-bottom: 0;
    }

    .accordion-item {
      background: rgba(10, 22, 42, 0.86);
      border: 1px solid rgba(144, 179, 255, 0.2) !important;
    }

    .accordion-button {
      background: rgba(12, 25, 48, 0.82);
      color: #e9efff;
      box-shadow: none;
    }

    .accordion-button:not(.collapsed) {
      background: rgba(19, 34, 61, 0.94);
      color: #f3f7ff;
    }

    .accordion-button::after {
      filter: invert(0.95);
    }

    .bg-light,
    .badge.text-bg-light {
      background: rgba(255, 255, 255, 0.1) !important;
      color: #eaf1ff !important;
      border-color: rgba(164, 192, 248, 0.28) !important;
    }

    .reveal-on-scroll {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }

    .reveal-on-scroll.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    footer {
      text-align: center;
      color: #9fb0d4;
      border-top: 1px solid rgba(148, 179, 240, 0.22);
      background: rgba(7, 14, 28, 0.86);
      padding: 1rem 0;
      position: relative;
      z-index: 2;
    }

    .toast {
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
      border-radius: 10px;
      animation: slideIn 0.5s ease forwards;
    }

    @keyframes slideIn {
      from {
        transform: translateX(100%);
        opacity: 0;
      }

      to {
        transform: translateX(0);
        opacity: 1;
      }
    }

    @media (max-width: 991.98px) {
      .hero-video-bg {
        min-height: 700px;
      }

      .premium-shell.home-hero .page-hero {
        min-height: 640px;
        align-items: flex-end;
        padding: 2.2rem 0 2.4rem;
      }

      .home-hero-content {
        min-height: 560px;
        justify-content: flex-start;
      }

      .home-hero-panel {
        margin-left: 0;
        margin-top: 1rem;
        max-width: none;
      }

      .home-hero-actions-panel {
        padding: 0;
      }

      .home-hero-lower {
        margin-top: 2rem;
      }

      .premium-shell::before {
        height: 250px;
      }

      .navbar-collapse {
        background: rgba(15, 27, 48, 0.86);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 0.8rem;
        margin-top: 0.75rem;
        padding: 0.65rem;
      }
    }
  </style>
</head>

<body class="<%= (typeof currentPath === 'string' && currentPath === '/') ? 'home-page' : '' %>">
  <%
    const path = typeof currentPath === 'string' ? currentPath : '/';
    const heroMap = {
      '/': { kicker: 'Privia Platform', title: 'Private identity proof. Instant trust.', subtitle: 'Encrypted claims. Time-limited proof sharing.', image: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=1920&q=80', video: 'https://videos.pexels.com/video-files/3130182/3130182-hd_1920_1080_30fps.mp4' },
      '/about': { kicker: 'About Privia', title: 'Identity verification without data overexposure', subtitle: 'A practical architecture for privacy-first trust decisions.', image: 'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1920&q=80' },
      '/how-it-works': { kicker: 'Workflow', title: 'See the full verification lifecycle', subtitle: 'Registration, claim approval, temporary proof generation, and live validation.', image: 'https://images.unsplash.com/photo-1563986768609-322da13575f3?auto=format&fit=crop&w=1920&q=80' },
      '/security': { kicker: 'Security', title: 'Defensive by design', subtitle: 'Encryption, hashing, expiry controls, and admin-governed verification.', image: 'https://images.unsplash.com/photo-1555949963-aa79dcee981c?auto=format&fit=crop&w=1920&q=80' },
      '/dashboard': { kicker: 'User Console', title: 'Control your verification proofs', subtitle: 'Generate and share secure, time-limited credentials.', image: 'https://images.unsplash.com/photo-1488590528505-98d2b5aba04b?auto=format&fit=crop&w=1920&q=80' },
      '/admin': { kicker: 'Operations', title: 'Admin verification command center', subtitle: 'Approve users, verify claims, and monitor trust pipeline activity.', image: 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&w=1920&q=80' },
      '/users/login': { kicker: 'Access', title: 'Secure account sign-in', subtitle: 'Authenticate to continue protected verification workflows.', image: 'https://images.unsplash.com/photo-1563986768609-322da13575f3?auto=format&fit=crop&w=1920&q=80' },
      '/users/register': { kicker: 'Onboarding', title: 'Create your Privia account', subtitle: 'Start secure registration with encrypted identity handling.', image: 'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1920&q=80' },
      '/scanner': { kicker: 'Live Scanner', title: 'Real-time proof validation', subtitle: 'Scan QR proofs and receive instant verification outcomes.', image: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=1920&q=80' }
    };

    const normalized = path.startsWith('/admin') ? '/admin' : path;
    const hero = heroMap[normalized] || heroMap['/'];
    const isHome = path === '/';
  %>

  <div class="premium-shell <%= isHome ? 'home-hero' : '' %>" style="--hero-image: url('<%= hero.image %>');">
    <% if (isHome) { %>
      <div class="hero-video-bg" aria-hidden="true">
        <video autoplay muted loop playsinline preload="metadata" poster="<%= hero.image %>">
          <source src="<%= hero.video %>" type="video/mp4">
        </video>
      </div>
    <% } %>

    <nav class="navbar navbar-expand-lg">
      <div class="container">
        <a class="navbar-brand" href="/">
          <span class="brand-mark"></span>
          <span class="brand-label">Privia</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navmenu">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navmenu">
          <ul class="navbar-nav ms-lg-4 me-auto">
            <li class="nav-item"><a class="nav-link <%= path === '/' ? 'active' : '' %>" href="/">Home</a></li>
            <li class="nav-item"><a class="nav-link <%= path === '/about' ? 'active' : '' %>" href="/about">About</a></li>
            <li class="nav-item"><a class="nav-link <%= path === '/how-it-works' ? 'active' : '' %>" href="/how-it-works">How It Works</a></li>
            <li class="nav-item"><a class="nav-link <%= path === '/security' ? 'active' : '' %>" href="/security">Security</a></li>
            <li class="nav-item"><a class="nav-link <%= path === '/scanner' ? 'active' : '' %>" href="/scanner">Scanner</a></li>
          </ul>

          <ul class="navbar-nav">
            <% if (typeof user !== 'undefined' && user) { %>
              <li class="nav-item"><a class="nav-link <%= path === '/dashboard' ? 'active' : '' %>" href="/dashboard">Dashboard</a></li>
              <% if (user.role === 'admin') { %>
                <li class="nav-item"><a class="nav-link <%= path.startsWith('/admin') ? 'active' : '' %>" href="/admin">Admin</a></li>
              <% } %>
              <li class="nav-item"><a class="nav-link" href="/users/logout">Logout</a></li>
            <% } else { %>
              <li class="nav-item"><a class="nav-link <%= path === '/users/login' ? 'active' : '' %>" href="/users/login">Login</a></li>
              <li class="nav-item"><a class="nav-link <%= path === '/users/register' ? 'active' : '' %>" href="/users/register">Register</a></li>
            <% } %>
          </ul>
        </div>
      </div>
    </nav>

    <section class="page-hero">
      <div class="container">
        <% if (isHome) { %>
          <div class="page-hero-card home-hero-content">
            <div class="row g-5 align-items-start home-hero-upper">
              <div class="col-lg-7">
                <span class="page-kicker"><%= hero.kicker %></span>
                <h1 class="page-hero-title home-hero-title"><%= hero.title %></h1>
                <p class="page-hero-subtitle home-hero-subtitle"><%= hero.subtitle %></p>
              </div>
            </div>

            <div class="row g-5 align-items-start home-hero-lower">
              <div class="col-lg-7">
                <div class="home-hero-actions-panel">
                  <div class="home-hero-actions">
                    <% if (typeof user !== 'undefined' && user) { %>
                      <a href="/dashboard" class="btn btn-lg btn-privia">Open Dashboard</a>
                      <a href="/scanner" class="home-hero-link">Open Scanner</a>
                    <% } else { %>
                      <a href="/users/register" class="btn btn-lg btn-privia">Create Account</a>
                      <a href="/users/login" class="home-hero-link">Login</a>
                    <% } %>
                  </div>

                  <div class="home-hero-points">
                    <span class="hero-point">AES encrypted identity data</span>
                    <span class="hero-point">Claim-first verification</span>
                  </div>
                </div>
              </div>

              <div class="col-lg-5">
                <div class="home-hero-panel">
                  <div class="home-hero-panel-row">
                    <span>Verification Access</span>
                    <strong>Admin-approved claims</strong>
                  </div>
                  <div class="home-hero-panel-row">
                    <span>Proof Lifetime</span>
                    <strong>30s</strong>
                  </div>
                  <p class="home-hero-panel-note">Only admin-approved claims can generate valid proof codes.</p>
                </div>
              </div>
            </div>
          </div>
        <% } else { %>
          <div class="page-hero-card standard">
            <span class="page-kicker"><%= hero.kicker %></span>
            <h1 class="page-hero-title"><%= hero.title %></h1>
            <p class="page-hero-subtitle"><%= hero.subtitle %></p>
          </div>
        <% } %>
      </div>
    </section>
  </div>

  <div id="toast-container" class="position-fixed top-0 end-0 p-3" style="z-index: 1100;">
    <%- include('./partials/messages') %>
  </div>

  <main class="container content-wrapper">
    <%- typeof body !== 'undefined' ? body : '' %>
  </main>

  <footer>
    <div class="container">
      © <%= new Date().getFullYear() %> Privia | Privacy-Preserving Identity Verification
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      document.querySelectorAll('.toast').forEach(toastEl => {
        const toast = new bootstrap.Toast(toastEl, { delay: 3000 });
        toast.show();
      });

      const revealItems = document.querySelectorAll('.reveal-on-scroll');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });

      revealItems.forEach((item) => observer.observe(item));
    });
  </script>
</body>

</html>
